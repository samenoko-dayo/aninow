---
import Layout from "../layouts/Layout.astro";
import NowOnAir from "../components/NowOnAir.astro";
import AnimeGrid from "../components/AnimeGrid.astro";
import { Tv } from "lucide-react";
import fs from "fs";
import path from "path";

async function getAnimeData() {
  const filePath = path.join(process.cwd(), "data", "anime.json");
  try {
    const fileContents = fs.readFileSync(filePath, "utf8");
    return JSON.parse(fileContents);
  } catch (error) {
    console.error("Failed to read anime.json", error);
    return null;
  }
}

const animeData = await getAnimeData();
const season = animeData?.season || "今期";
const updatedAt = animeData?.updated_at || "";
const works = animeData?.works || [];
---

<Layout>
  <main class="min-h-screen bg-slate-50 font-sans text-slate-900 selection:bg-indigo-500/30">
    {/* Background decoration */}
    <div class="fixed inset-0 z-0 bg-slate-50"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 pt-12 sm:px-6 lg:px-8 lg:pt-20">

      {/* Header */}
      <header class="mb-16 flex flex-col items-center justify-center text-center space-y-4">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-indigo-600 shadow-md">
          <Tv size={32} className="text-white" />
        </div>
        <div class="flex flex-col items-center gap-2">
          <h1 class="text-5xl font-black tracking-tighter sm:text-7xl">
            <span class="text-indigo-600">
              AniNow
            </span>
          </h1>
          <div class="inline-flex items-center rounded-2xl bg-indigo-50 px-4 py-2 text-xl font-black text-indigo-600 border-2 border-indigo-100 shadow-sm">
            {season}
          </div>
        </div>
        <p class="max-w-xl text-lg text-slate-600 font-medium break-keep">
          今やっているアニメをチェックしよう！
        </p>
        {updatedAt && (
          <div class="inline-flex items-center gap-2 rounded-lg bg-slate-100 px-3 py-1 text-xs font-bold text-slate-500 uppercase tracking-wider">
            <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>
            最終更新: {updatedAt}
          </div>
        )}
      </header>

      {works.length > 0 ? (
        <>
          <NowOnAir animeList={works} />
          <AnimeGrid animeList={works} />
        </>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 text-center text-slate-400">
          <Tv size={48} className="mb-4 opacity-40" />
          <p class="text-xl font-medium">今期の番組データが見つかりませんでした。</p>
        </div>
      )}

      <footer class="py-8 text-slate-500">
        <div class='flex flex-col items-center justify-center gap-2'>
          <div class='flex items-center gap-2'>
            <Tv size={24} className="text-indigo-600" />
            <p class='text-lg font-bold'>AniNow</p>
          </div>
          <div class='flex flex-row items-center gap-2 text-white font-bold'>
            <a class='px-4 py-2 bg-indigo-600 rounded-xl' href="https://github.com/samenoko-dayo/aninow" target='_blank'>Source</a>
            <a class='px-4 py-2 bg-indigo-600 rounded-xl' href="https://annict.com" target='_blank'>Annict</a>
            <a class='px-4 py-2 bg-indigo-600 rounded-xl' href="/about">About</a>
          </div>
        </div>
      </footer>
    </div>
  </main>
</Layout>
